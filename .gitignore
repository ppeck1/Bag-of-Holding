# Secrets / credentials — never track
.env
*.env
!.env.example
*.pem
*.key
*.p12
*.pfx

# Loose log files (logs/ dir already excluded above)
*.log

# Public-export workflow: the export dir lives OUTSIDE the repo
# (../Bag-of-Holding-public-export); these guard against accidental
# in-repo export output.
public-export/
Bag-of-Holding-public-export/

# Local export/backup scratch (source snapshots, browser-automation profiles).
# Untracked dev scratch only — exclude the whole directory from staging.
# Contents are intentionally NOT deleted; this rule only keeps Git from staging them.
export/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
