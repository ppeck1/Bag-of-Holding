# Bag of Holding — example environment configuration
#
# NOTE: BOH reads ordinary PROCESS environment variables; it does not load this
# file automatically. Copy the values you need into your shell profile,
# launcher wrapper, or service definition.
# All values below are local placeholders — BOH has no hosted credentials.
#
#   PowerShell:  $env:BOH_OPERATOR_TOKEN = "change-me-local"
#   bash/zsh:    export BOH_OPERATOR_TOKEN=change-me-local

# --- Core paths --------------------------------------------------------------
# Server-owned document library root (filesystem authority boundary).
BOH_LIBRARY=./library
# SQLite database path.
BOH_DB=boh.db

# --- Authorization -----------------------------------------------------------
# Mutation gate. Unset = dev-open mode (protected routes open; UI shows a
# DEV-OPEN badge). Set it for anything beyond throwaway local evaluation.
BOH_OPERATOR_TOKEN=change-me-local
# Read-only connector gate for /api/retrieve and /api/context-object.
# Separate from the operator token by design — never give connectors the
# operator token.
BOH_RETRIEVAL_TOKEN=change-me-readonly
# Dual gate for promoted intake documents in retrieval (with per-request
# include_promoted). Default false; fail-closed.
BOH_RETRIEVAL_INCLUDE_PROMOTED=false

# --- Governed intake (all optional; scheduler is inert by default) ------------
# Root for RAW preservation / normalized artifacts (required for intake runs).
#BOH_DATA_ROOT=./data
# Scheduler master switch + watch configuration.
#BOH_INTAKE_SCHEDULER_ENABLED=false
#BOH_WATCH_PATH=
#BOH_INTAKE_IGNORE_PATTERNS=
#BOH_INTAKE_SCAN_INTERVAL=30
#BOH_INTAKE_DRAIN_TIMEOUT=30.0

# --- Indexing / review -------------------------------------------------------
#BOH_AUTO_INDEX=false
#BOH_AUTO_INDEX_MAX_FILES=5000
#BOH_DETERMINISTIC_REVIEW_ON_INDEX=true
#BOH_LLM_REVIEW_ON_INDEX=false

# --- Optional local LLM (Ollama) ----------------------------------------------
#BOH_OLLAMA_ENABLED=false
#BOH_OLLAMA_URL=http://localhost:11434
#BOH_OLLAMA_MODEL=llama3.2
